---
const pathname = new URL(Astro.request.url).pathname;
const isCurrent = (path: string) => {
  if (path === '/') {
    return pathname === '/' || pathname === '';
  }
  return pathname.startsWith(path);
};
---

<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <a href="/" class="profile-container">
      <img src="/images/avatar.jpg" alt="Jared Rounsavall" class="avatar" />
      <div class="profile-info">
        <h3>Jared Rounsavall</h3>
        <p class="role">Software Engineer & Tech Lead</p>
      </div>
    </a>
    <button class="mobile-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" y1="12" x2="20" y2="12" class="line-1"></line>
        <line x1="4" y1="6" x2="20" y2="6" class="line-2"></line>
        <line x1="4" y1="18" x2="20" y2="18" class="line-3"></line>
      </svg>
    </button>
  </div>

  <div class="sidebar-content" id="sidebarContent">
    <nav class="nav-links">
      <a href="/" class={isCurrent('/') ? 'active' : ''}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
        <span>About & CV</span>
      </a>
      <!-- <a href="/blog" class={isCurrent('/blog') ? 'active' : ''}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2-2.5z"></path><path d="M6 6h10M6 10h10"></path></svg>
        <span>Thoughts</span>
      </a> -->
    </nav>

    <div class="sidebar-footer">
      <!-- Dark mode toggle -->
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
        <!-- Sun icon -->
        <svg class="sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <!-- Moon icon -->
        <svg class="moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
        <span class="theme-text">Toggle Theme</span>
      </button>

      <!-- Socials -->
      <div class="social-links">
        <a href="https://github.com/jrounsav" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
        </a>
        <a href="https://linkedin.com/in/jared-rounsavall" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
      </div>
    </div>
  </div>
</aside>

<script>
  const mobileToggle = document.getElementById('mobileMenuToggle');
  const sidebar = document.getElementById('sidebar');
  
  mobileToggle?.addEventListener('click', () => {
    sidebar?.classList.toggle('expanded');
  });

  // Close sidebar on link click (mobile)
  const navLinks = document.querySelectorAll('.nav-links a');
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      sidebar?.classList.remove('expanded');
    });
  });
</script>

<style>
  .sidebar {
    width: 100%;
    background-color: var(--bg-sidebar);
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    position: relative;
    z-index: 100;
    display: flex;
    flex-direction: column;
    transition: var(--transition);
  }

  @media (min-width: 1024px) {
    .sidebar {
      width: 320px;
      height: 100vh;
      position: fixed;
      left: 0;
      top: 0;
      border-right: 1px solid var(--border);
      border-bottom: none;
      padding: 3rem 2rem;
    }
  }

  .sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .profile-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--text-primary);
    text-decoration: none;
  }

  @media (min-width: 1024px) {
    .profile-container {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      width: 100%;
    }
  }

  .avatar {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 2px solid var(--accent);
    box-shadow: var(--shadow);
  }

  @media (min-width: 1024px) {
    .avatar {
      width: 96px;
      height: 96px;
      border-width: 3px;
    }
  }

  .profile-info h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
  }

  @media (min-width: 1024px) {
    .profile-info h3 {
      font-size: 1.4rem;
      margin-bottom: 0.35rem;
    }
  }

  .role {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  .mobile-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-primary);
    display: block;
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    transition: var(--transition-fast);
  }

  .mobile-toggle:hover {
    background-color: var(--border);
  }

  @media (min-width: 1024px) {
    .mobile-toggle {
      display: none;
    }
  }

  /* Expandable content for mobile */
  .sidebar-content {
    display: none;
    flex-direction: column;
    margin-top: 1.5rem;
    gap: 2rem;
    flex-grow: 1;
  }

  @media (min-width: 1024px) {
    .sidebar-content {
      display: flex;
      margin-top: 3.5rem;
    }
  }

  /* When expanded on mobile */
  .sidebar.expanded .sidebar-content {
    display: flex;
  }

  /* Nav Navigation styling */
  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-links a {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem 1rem;
    color: var(--text-secondary);
    font-weight: 500;
    border-radius: var(--radius-md);
    transition: var(--transition-fast);
  }

  .nav-links a:hover, .nav-links a.active {
    background-color: var(--border);
    color: var(--text-primary);
  }

  .nav-links a.active {
    color: var(--accent);
    font-weight: 600;
  }

  .sidebar-footer {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: auto;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  /* Theme Toggle button */
  .theme-toggle {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    background: none;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    padding: 0.6rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: var(--transition-fast);
    width: 100%;
  }

  .theme-toggle:hover {
    background-color: var(--border);
    color: var(--text-primary);
  }

  .sun-icon {
    display: none;
  }

  :global(html[data-theme="dark"]) .sun-icon {
    display: block;
  }

  :global(html[data-theme="dark"]) .moon-icon {
    display: none;
  }

  /* Social links container */
  .social-links {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-start;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    transition: var(--transition-fast);
  }

  .social-links a:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }
</style>
